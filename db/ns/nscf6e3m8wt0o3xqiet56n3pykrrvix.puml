@startnwdiag
nwdiag {
  // define group at outside network definitions
  group {
    color = "#FF7777";
    description = "long group label";
    'shape = node;

    web01;
    web02;
    db01;
  }

  network dmz {
    web01;
    web02;
  }
  network internal {
    web01;
    web02;
    db01 [address = ".101", shape = database];
  }
}
@endnwdiag
